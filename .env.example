# MAJESTICMuseMedia.ai Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# App
VITE_APP_ENV=development

# Firebase (required for authentication and database)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# YouTube (optional - enables YouTube integration)
VITE_YOUTUBE_API_KEY=
VITE_YOUTUBE_CHANNEL_ID=

# Twitch (optional - enables Twitch live streaming)
VITE_TWITCH_CLIENT_ID=

# KICK (optional - enables KICK live streaming)
VITE_KICK_API_KEY=

# Google (optional - enables Drive and Calendar integration)
VITE_GOOGLE_CLIENT_ID=
