# Browser application — Firebase web configuration is public project metadata, not a server credential.
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:8080
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Local development only. Keep false in staging and production.
VITE_ENABLE_DEMO_AUTH=false

# Trusted server runtime — store production values in Secret Manager, never in Git.
NODE_ENV=development
PORT=8080
GOOGLE_CLOUD_PROJECT=
FIREBASE_PROJECT_ID=
APP_ORIGIN=http://localhost:5173
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.6-flash
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8080/api/oauth/youtube/callback
TOKEN_ENCRYPTION_KEY=
ENABLE_EXTERNAL_ACTIONS=false

# Reserved for later trusted adapters.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
