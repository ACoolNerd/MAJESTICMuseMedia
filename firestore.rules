rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function role() { return signedIn() ? request.auth.token.role : null; }
    function hasRole(roles) { return role() in roles; }
    function staff() { return hasRole(['ceo','coo','post','social','crew']); }
    function executive() { return hasRole(['ceo','coo']); }
    function contentOperator() { return hasRole(['ceo','coo','post','social']); }
    function mediaOperator() { return hasRole(['ceo','coo','post']); }
    function growthOperator() { return hasRole(['ceo','coo','social']); }
    function self(uid) { return signedIn() && request.auth.uid == uid; }
    function validPublicFormSubmission() {
      return request.resource.data.keys().hasOnly([
          'formType', 'consent', 'source', 'payload', 'status', 'submittedAt'
        ]) &&
        request.resource.data.formType in [
          'guest-interest',
          'guest-preparation',
          'community-story',
          'guest-suggestion',
          'sponsor-inquiry',
          'media-services',
          'newsletter',
          'viewer-feedback'
        ] &&
        request.resource.data.consent == true &&
        request.resource.data.status == 'New' &&
        request.resource.data.source is string &&
        request.resource.data.source.size() <= 500 &&
        request.resource.data.payload is map &&
        request.resource.data.payload.keys().size() <= 30 &&
        request.resource.data.submittedAt == request.time;
    }

    match /publicContent/{document=**} {
      allow read: if true;
      allow write: if executive();
    }

    match /users/{uid} {
      allow read: if self(uid) || executive();
      allow create, delete: if executive();
      allow update: if executive() || (
        self(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'photoURL', 'updatedAt'
        ])
      );
    }

    match /episodes/{episodeId} {
      allow read: if staff();
      allow create, update: if contentOperator();
      allow delete: if executive();
    }

    match /guests/{guestId} {
      allow read: if staff() || (signedIn() && resource.data.ownerUid == request.auth.uid);
      allow create, update: if contentOperator();
      allow delete: if executive();
    }

    match /guestDocuments/{documentId} {
      allow read: if executive() || hasRole(['post']) || (signedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if executive() || (signedIn() && request.resource.data.ownerUid == request.auth.uid);
      allow update: if executive() || (signedIn() && resource.data.ownerUid == request.auth.uid && request.resource.data.ownerUid == request.auth.uid);
      allow delete: if executive();
    }

    match /tasks/{taskId} {
      allow read: if staff();
      allow create, update: if staff();
      allow delete: if executive();
    }

    match /approvals/{approvalId} {
      allow read: if staff();
      allow create, update: if contentOperator();
      allow delete: if executive();
    }

    match /rightsRecords/{recordId} {
      allow read: if hasRole(['ceo','coo','post']);
      allow create, update: if hasRole(['ceo','coo','post']);
      allow delete: if executive();
    }

    match /mediaAssets/{assetId} {
      allow read: if staff();
      allow create, update: if mediaOperator();
      allow delete: if executive();
    }

    match /reviewVersions/{versionId} {
      allow read: if staff();
      allow create, update: if mediaOperator();
      allow delete: if executive();
    }

    match /reviewComments/{commentId} {
      allow read: if staff();
      allow create: if contentOperator() && request.resource.data.authorUid == request.auth.uid;
      allow update: if mediaOperator() || (
        signedIn() &&
        resource.data.authorUid == request.auth.uid &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'body', 'category', 'severity', 'resolved', 'resolvedAt'
        ])
      );
      allow delete: if executive();
    }

    match /capcutPackets/{packetId} {
      allow read: if contentOperator();
      allow create, update: if mediaOperator();
      allow delete: if executive();
    }

    match /formSubmissions/{submissionId} {
      allow create: if validPublicFormSubmission();
      allow read, update: if executive() || hasRole(['social']);
      allow delete: if executive();
    }

    // Metadata only. Tokens and secrets remain in the trusted server secret store.
    match /platformConnections/{connectionId} {
      allow read: if staff();
      allow create, update, delete: if hasRole(['coo']);
    }

    // Encrypted OAuth credentials are trusted-server-only and invisible to all clients.
    match /platformCredentials/{credentialId} {
      allow read, write: if false;
    }

    match /liveEvents/{eventId} {
      allow read: if staff();
      allow create, update: if contentOperator();
      allow delete: if executive();
    }

    match /distributionJobs/{jobId} {
      allow read: if staff();
      allow create: if contentOperator() && request.resource.data.status in ['Draft', 'Waiting Approval'];
      allow update: if contentOperator() &&
        !(request.resource.data.status in ['Processing', 'Succeeded', 'Failed']) &&
        (request.resource.data.status != 'Approved' || role() == 'ceo');
      allow delete: if executive();
    }

    match /sourceRegistry/{sourceId} {
      allow read: if staff();
      allow create, update, delete: if executive();
    }

    match /analyticsSnapshots/{snapshotId} {
      allow read: if staff();
      allow create, update: if executive();
      allow delete: if executive();
    }

    match /leads/{leadId} {
      allow read: if growthOperator();
      allow create, update: if growthOperator();
      allow delete: if executive();
    }

    match /repurposingMoments/{momentId} {
      allow read: if contentOperator();
      allow create, update: if contentOperator();
      allow delete: if executive();
    }

    // Trusted Gemini and server-generated outputs only. Client writes are denied.
    match /aiConversations/{conversationId} {
      allow read: if executive();
      allow create, update, delete: if false;
    }

    // Trusted Admin SDK / server runtime only. Client writes are always denied.
    match /auditLogs/{logId} {
      allow read: if executive();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
