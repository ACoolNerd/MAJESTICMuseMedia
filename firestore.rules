rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function role() { return signedIn() ? request.auth.token.role : null; }
    function staff() { return role() in ['ceo','coo','post','social','crew']; }
    function executive() { return role() in ['ceo','coo']; }

    match /publicContent/{document=**} {
      allow read: if true;
      allow write: if executive();
    }
    match /episodes/{episodeId} {
      allow read: if staff();
      allow create, update: if role() in ['ceo','coo','post','social'];
      allow delete: if executive();
    }
    match /guestDocuments/{document=**} {
      allow read, write: if executive();
    }
    match /auditLogs/{logId} {
      allow read: if executive();
      allow create: if signedIn();
      allow update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if staff();
    }
  }
}
